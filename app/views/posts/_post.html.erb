<div id="<%= dom_id post %>">
  <div>
    <strong>Title:</strong>
    <%= post.title %>
  </div>

  <div>
    <strong>Body:</strong>
    <%= post.body %>
  </div>

  <div>
    <strong>Published:</strong>
    <%= post.published %>
  </div>

  <div>
    <strong>Views:</strong>
    <%= post.views_count %>
  </div>

</div>
