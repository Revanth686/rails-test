<p style="color: green"><%= notice %></p>

<% content_for :title, "Posts" %>

<h1>Posts</h1>

<%= form_with url: posts_path, method: :get do |f| %>
  <%= f.search_field :q, value: params[:q], placeholder: "Search posts…" %>
  <%= f.hidden_field :tag, value: params[:tag] if params[:tag].present? %>
  <%= f.select :sort, [["Newest", "newest"], ["Oldest", "oldest"], ["Most viewed", "popular"]], { selected: params[:sort] || "newest" }, { onchange: "this.form.submit()" } %>
  <%= f.submit "Search" %>
  <% if params[:q].present? || params[:tag].present? %>
    <%= link_to "Clear", posts_path %>
  <% end %>
<% end %>

<% if params[:tag].present? %>
  <p>Filtering by tag: <strong><%= params[:tag] %></strong></p>
<% end %>

<div id="posts">
  <% @posts.each do |post| %>
    <%= render post %>
    <p>
      <%= link_to "Show this post", post %>
    </p>
  <% end %>
</div>

<%= link_to "New post", new_post_path %>
